# ESP-IDF build artifacts
build/
*.bin
*.elf
*.map
sdkconfig.old

# Local board config — holds Wi-Fi creds. Share defaults via sdkconfig.default
# instead; regenerate the local sdkconfig with ./setup.sh or `idf.py set-target`.
/sdkconfig

# IDE-specific files
.vscode/
*.code-workspace

# Logs or test data
*.log
*.pyc
__pycache__/
frames/

# Server runtime certs/keys — regenerate with server/make-certs.sh.
# (The firmware's trusted copy, components/net/certs/server_ca.pem, IS committed.)
server/cert.pem
server/key.pem
server/_local_cert/

# Local dev aids / agent state — not for the repo
CLAUDE.md
.claude/